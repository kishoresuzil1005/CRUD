pipeline {
    agent any

    environment {
        SOURCE_BRANCH = "dev"
        DEST_BRANCH = "main"
        REPO_URL = "https://github.com/kishoresuzil1005/CRUD.git"
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: "${SOURCE_BRANCH}",
                    url: "${REPO_URL}",
                    credentialsId: 'github-access-token'
            }
        }

        stage('Build') {
            steps {
                sh '''
                npm install
                npm run build
                '''
            }
        }

        stage('Merge to Destination') {
            steps {
                sh '''
                git config user.name "kishoresuzil1005"
                git config user.email "kishoresuzil1005@gmail.com"

                git checkout ${DEST_BRANCH} || git checkout -b ${DEST_BRANCH}
                git merge ${SOURCE_BRANCH}
                git push origin ${DEST_BRANCH}
                '''
            }
        }
    }
}
